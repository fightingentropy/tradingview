{
  "name": "tradingview",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@msgpack/msgpack": "^3.1.3",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.6.2",
    "@tanstack/query-sync-storage-persister": "5.101.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "5.101.0",
    "expo": "~56.0.12",
    "expo-background-task": "~56.0.20",
    "expo-constants": "~56.0.18",
    "expo-font": "~56.0.7",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-linking": "~56.0.14",
    "expo-notifications": "~56.0.19",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-task-manager": "~56.0.20",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "^4.3.1",
    "react-native-reanimated": "4.3.1",
    "react-native-reorderable-list": "^0.18.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "victory-native": "^41.26.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "@types/react": "~19.2.2",
    "@typescript/native": "npm:typescript@^7.0.2",
    "cheerio": "^1.1.2",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~56.0.4",
    "telegram": "^2.26.22",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "wrangler": "^4.110.0"
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:sim:release": "expo run:ios --configuration Release --no-bundler",
    "web": "expo start --web",
    "news:server": "node scripts/news-feed-server.mjs",
    "news:install": "node scripts/news-service.mjs install",
    "news:uninstall": "node scripts/news-service.mjs uninstall",
    "test:news-push": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test scripts/news-notification-sources.test.mjs",
    "test:digg": "node --test scripts/digg-tech.test.mjs",
    "test:paste": "node --test scripts/paste-trade.test.mjs",
    "test:chart": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test scripts/chart-crosshair.test.mjs",
    "test:news-refresh": "node --test scripts/news-refresh-policy.test.mjs",
    "test:news-summary": "node --test scripts/news-executive-summary.test.mjs",
    "test:trading": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test scripts/account-risk.test.mjs scripts/chart-crosshair.test.mjs scripts/execution-estimate.test.mjs scripts/trade-preflight.test.mjs && npm run verify:signing && npm run verify:identity",
    "relay:deploy": "node scripts/news-relay-deploy.mjs",
    "relay:dev": "wrangler dev",
    "telegram:login": "node scripts/telegram-login.mjs",
    "lint": "expo lint",
    "typecheck": "node node_modules/@typescript/native/bin/tsc --noEmit && npm run typecheck:worker",
    "typecheck:worker": "wrangler types worker/worker-configuration.d.ts && node node_modules/@typescript/native/bin/tsc -p worker/tsconfig.json",
    "verify:signing": "npx tsx scripts/verify-hl-signing.mts",
    "verify:identity": "npx tsx scripts/verify-trading-identity.mts"
  },
  "private": true
}
