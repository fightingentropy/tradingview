{
  "cli": {
    "version": ">= 20.5.1"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "env": {
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      }
    }
  }
}
