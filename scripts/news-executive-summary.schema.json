{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "headline",
    "overview",
    "pulse",
    "bullets",
    "watchNext",
    "noiseSummary"
  ],
  "properties": {
    "headline": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "overview": {
      "type": "string",
      "minLength": 1,
      "maxLength": 700
    },
    "pulse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "summary"],
      "properties": {
        "label": {
          "type": "string",
          "enum": ["risk-on", "risk-off", "mixed", "calm", "event-driven"]
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 400
        }
      }
    },
    "bullets": {
      "type": "array",
      "minItems": 3,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["headline", "summary", "whyItMatters", "details", "sourceKeys"],
        "properties": {
          "headline": {
            "type": "string",
            "minLength": 1,
            "maxLength": 110
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 360
          },
          "whyItMatters": {
            "type": "string",
            "minLength": 1,
            "maxLength": 420
          },
          "details": {
            "type": "string",
            "minLength": 1,
            "maxLength": 900
          },
          "sourceKeys": {
            "type": "array",
            "minItems": 1,
            "maxItems": 6,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 300
            }
          }
        }
      }
    },
    "watchNext": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 240
      }
    },
    "noiseSummary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 400
    }
  }
}
