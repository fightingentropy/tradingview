{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "headline",
    "overview",
    "pulse",
    "bullets",
    "secondarySignals",
    "watchNext",
    "noiseSummary"
  ],
  "properties": {
    "headline": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "overview": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "pulse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "summary"],
      "properties": {
        "label": {
          "type": "string",
          "enum": ["risk-on", "risk-off", "mixed", "calm", "event-driven"]
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 180
        }
      }
    },
    "bullets": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["headline", "summary", "marketImpact", "details", "change", "confidence", "sourceKeys"],
        "properties": {
          "headline": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 220
          },
          "marketImpact": {
            "type": "string",
            "minLength": 1,
            "maxLength": 180
          },
          "details": {
            "type": "string",
            "minLength": 1,
            "maxLength": 600
          },
          "change": {
            "type": "string",
            "enum": ["new", "changed", "unchanged"]
          },
          "confidence": {
            "type": "string",
            "enum": ["confirmed", "reported", "disputed", "speculative"]
          },
          "sourceKeys": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 300
            }
          }
        }
      }
    },
    "secondarySignals": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 140
      }
    },
    "watchNext": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 160
      }
    },
    "noiseSummary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 220
    }
  }
}
